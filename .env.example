# Postgres connection (Railway provides one — copy the connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB"

# Shared secret for the access lock. Visit /unlock?key=$APP_SHARED_SECRET to bookmark.
APP_SHARED_SECRET="change-me-to-a-long-random-string"

# Used to HMAC-sign the auth cookie (any long random string)
COOKIE_SECRET="another-long-random-string"
